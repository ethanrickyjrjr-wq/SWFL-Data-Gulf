{
  "mcpServers": {
    "serena": {
      "command": "serena",
      "args": ["start-mcp-server", "--context", "claude-code", "--project", "."]
    },
    "swfl": {
      "type": "http",
      "url": "https://www.swfldatagulf.com/api/mcp",
      "headersHelper": "node -e \"process.stdout.write(JSON.stringify({'X-Account-Key':process.env.SWFL_MCP_KEY||''}))\""
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=jtkdowmrjaxfvwmemxso"
    },
    "ezhomesearch": {
      "type": "http",
      "url": "https://www.ezhomesearch.com/mcp",
      "oauth": {
        "clientId": "aNx3H5VIPeDIfUgY4wA4yRlqY1_UK1q0JPaO2cyqhzY"
      }
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "designlang": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "designlang@12.21.0", "mcp"]
    },
    "figma": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key=${FIGMA_API_KEY:-}",
        "--stdio"
      ]
    }
  }
}
