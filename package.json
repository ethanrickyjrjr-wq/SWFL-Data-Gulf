{
  "name": "brain-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "orphans": "node scripts/check-orphans.mjs",
    "dev": "next dev",
    "email:dev": "email dev",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "knip": "knip",
    "test": "bun test",
    "refinery": "bun refinery/cli.mts",
    "refinery:franchise": "bun refinery/cli.mts franchise-outcomes",
    "refinery:cre": "bun refinery/cli.mts cre-swfl",
    "refinery:typecheck": "tsc -p refinery/tsconfig.json --noEmit",
    "fixtures:corridors": "bun refinery/tools/regen-corridor-fixture.mts",
    "ledger": "bun refinery/tools/semantic-ledger.mts",
    "roadmap:sync": "bun refinery/tools/roadmap-sync.mts",
    "triage": "bun refinery/tools/orphan-triage.mts",
    "snapshot:corridor-character": "bun refinery/tools/pull-corridor-character-snapshot.mts",
    "pgvector:verify": "bun refinery/tools/verify-pgvector.mts",
    "graphify:app": "node scripts/graphify-app-nodes.mjs",
    "graphify:update": "graphify update . && node scripts/graphify-app-nodes.mjs && bun scripts/graphify-snapshot.mjs save",
    "graphify:publish": "graphify update . && node scripts/graphify-app-nodes.mjs && node scripts/graphify-publish.mjs && bun scripts/graphify-snapshot.mjs save",
    "graphify:snapshot-save": "bun scripts/graphify-snapshot.mjs save",
    "graphify:snapshot-restore": "bun scripts/graphify-snapshot.mjs restore",
    "embed-concepts": "bun refinery/tools/embed-all-concepts.mts",
    "vault:capture": "bun refinery/tools/vault-capture.mts",
    "vault:list": "bun refinery/tools/vault-list.mts",
    "vault:export": "bun refinery/tools/vault-export.mts",
    "ingest:cbp": "cd ingest && python -m pipelines.census_cbp.pipeline",
    "ingest:fema": "cd ingest && python -m pipelines.fema.pipeline",
    "ingest:leepa": "cd ingest && python -m pipelines.leepa.pipeline",
    "ingest:fdot": "cd ingest && python -m pipelines.fdot.pipeline",
    "ingest:all": "npm run ingest:fema && npm run ingest:leepa && npm run ingest:fdot && npm run ingest:cbp",
    "ingest:storm-history-swfl": "python -m ingest.duckdb_pipelines.storm_history_swfl.pipeline",
    "ingest:redfin-swfl": "python -m ingest.duckdb_pipelines.redfin_swfl.pipeline",
    "ingest:zori-swfl:tier1": "python -m ingest.duckdb_pipelines.zori_swfl.pipeline",
    "ingest:zori-swfl:tier2": "python -m ingest.pipelines.zori_swfl.pipeline",
    "ingest:zori-swfl": "npm run ingest:zori-swfl:tier1 && npm run ingest:zori-swfl:tier2",
    "ingest:zhvi-swfl:tier1": "python -m ingest.duckdb_pipelines.zhvi_swfl.pipeline",
    "ingest:zhvi-swfl:tier2": "python -m ingest.pipelines.zhvi_swfl.pipeline",
    "ingest:zhvi-swfl": "npm run ingest:zhvi-swfl:tier1 && npm run ingest:zhvi-swfl:tier2",
    "gen:types": "bun scripts/gen-supabase-types.ts",
    "check:schema-drift": "bun scripts/check-schema-drift.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@duckdb/node-api": "1.5.4-r.1",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notionhq/client": "^5.22.0",
    "@number-flow/react": "^0.5.4",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@react-pdf/renderer": "4.5.1",
    "@resvg/resvg-js": "2.6.2",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@visx/curve": "^4.0.0",
    "@visx/event": "^4.0.0",
    "@visx/gradient": "^4.0.0",
    "@visx/grid": "^4.0.0",
    "@visx/group": "^4.0.0",
    "@visx/heatmap": "^4.0.0",
    "@visx/pattern": "^4.0.0",
    "@visx/responsive": "^4.0.0",
    "@visx/scale": "^4.0.0",
    "@visx/shape": "^4.0.0",
    "d3-shape": "^3.2.0",
    "dotenv": "^17.4.2",
    "echarts": "^6.1.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.21.0",
    "mcp-handler": "^1.1.0",
    "motion": "^12.42.0",
    "next": "16.2.9",
    "nextjs-nav-guard": "^1.0.5",
    "pdf-parse": "2.4.5",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-filerobot-image-editor": "^5.0.0-beta.159",
    "react-grid-layout": "^2.2.3",
    "react-konva": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-pdf": "10.4.1",
    "recharts": "^3.9.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.16.0",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "styled-components": "^6.4.3",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mts,mjs,json}": "prettier --write",
    "*.{ts,tsx,js,jsx,mts,mjs}": "eslint --fix --max-warnings=0 --no-warn-ignored"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@modelcontextprotocol/inspector": "0.22.0",
    "@playwright/test": "^1.61.1",
    "@react-email/ui": "^6.6.8",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^20.19.43",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-storybook": "^10.4.6",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.0",
    "react-email": "^6.6.8",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "type-fest": "^5.7.0",
    "typescript": "6",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
