  "_meta": {
    "what": "Share of parcels classified condominium, per ZIP, for the Lee + Collier footprint.",
    "why": "Turns the always-shown SB 4-D / condo caveat on the Should I Sell read into a concrete, per-area number (a caveat that self-calibrates: loud in condo-heavy Naples/Marco, near-zero inland).",
    "source": { "label": "SWFL Data Gulf", "url": "https://www.swfldatagulf.com" },
    "source_detail": "County assessment rolls held in the SWFL lake — Lee (LeePA, use_code 04 = CONDOMINIUM) + Collier (FDOR, dor_uc 004). Straddle ZIPs (34110, 34134) combine both counties.",
    "as_of": "07/11/2026",
    "grain": "Structural, slow-changing (annual roll). Regenerate on a roll refresh — this is a derived aggregate of real parcel records, never a live per-request scan.",
    "regen_sql": "leepa_parcels: COUNT(*) FILTER (WHERE use_code='04') / COUNT(*) GROUP BY zip_code; collier_parcels: dor_uc='004' GROUP BY phy_zipcd; UNION, sum straddle ZIPs, as_of = strftime(to_timestamp(max(_dlt_load_id::double)))."
  },
